# -----------------------------------------------------------------------------
# Server-only: this file is for the Node/Bun server process — not for browsers.
# - Do NOT prefix with NEXT_PUBLIC_* (that would embed values in client bundles).
# - Do NOT rely on these variables from Client Components or shared client modules.
# -----------------------------------------------------------------------------
#
# Optional: absolute path to the SQLite database file on the machine running the server.
# If unset or empty, getTodoSqliteDatabasePath() uses:
#   <project root>/.data/todos.sqlite
# (see src/server/todo-sqlite-path.ts)
#
# Examples (non-secret paths only):
#   TODO_SQLITE_PATH=/home/you/dev/todos.sqlite
#   TODO_SQLITE_PATH=C:/Users/you/AppData/Local/local-todo/todos.sqlite
#
# Local dev: copy this file to `.env.local`, or run `bun run env:bootstrap`.
# Next.js loads `.env.local` automatically for `bun run dev` / `bun run build`.
# Do not commit `.env.local` or real secrets.
TODO_SQLITE_PATH=
