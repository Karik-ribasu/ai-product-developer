# Server-only SQLite file path (never expose as NEXT_PUBLIC_*).
# Default when unset: .data/todos.sqlite under this package (see README).
SQLITE_PATH=

# PostgreSQL (Prisma / application persistence). Match docker-compose.postgres.yml for local dev.
# Never point at shared production or staging databases.
#
# From the host (Next.js on your machine, Postgres from docker-compose.postgres.yml on port 5432):
# DATABASE_URL=postgresql://todo:todos@127.0.0.1:5432/todo_reference_dev?schema=public
#
# From a container on the same Compose network as the `postgres` service (integration/E2E stacks set this automatically):
# DATABASE_URL=postgresql://todo:todos@postgres:5432/<database_name>?schema=public
DATABASE_URL=
